# Atlas API environment profiles
# APP_ENV must be one of: local | staging | prod

#######################################
# Local profile defaults (safe values)
#######################################
APP_ENV=local
LOAD_DOTENV=true
APP_NAME=atlas-api
API_SERVER_ADDR=:8080
LOG_LEVEL=debug
POSTGRES_URL=postgres://atlas:atlas@localhost:5432/atlas?sslmode=disable
REDIS_ADDR=localhost:6379
ASSET_STORAGE_BACKEND=local
ASSET_STORAGE_BUCKET=atlas-assets
MINIO_ENDPOINT=localhost:9000
MINIO_ROOT_USER=atlasminio
MINIO_ROOT_PASSWORD=atlasminio
MINIO_USE_SSL=false
MAILHOG_SMTP_ADDR=localhost:1025
JWT_SECRET=atlas-local-dev-secret
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_HOURS=720
USDA_API_BASE_URL=https://api.nal.usda.gov/fdc/v1
USDA_API_KEY=DEMO_KEY
EDAMAM_API_BASE_URL=https://api.edamam.com
EDAMAM_APP_ID=
EDAMAM_APP_KEY=
FOOD_DETAILS_CACHE_TTL_MINUTES=60
PRO_ALL_USERS=false
PRO_USER_EMAILS=

############################################################
# Staging/Prod required variables (do not commit real values)
############################################################
# APP_ENV=staging
# APP_NAME=atlas-api
# API_SERVER_ADDR=:8080
# LOG_LEVEL=info
# POSTGRES_URL=postgres://<user>:<password>@<host>:5432/<db>?sslmode=require
# REDIS_ADDR=<redis-host>:6379
# ASSET_STORAGE_BACKEND=s3
# ASSET_STORAGE_BUCKET=<bucket-name>
# MINIO_ENDPOINT=<s3-endpoint-or-minio-host>
# MINIO_ROOT_USER=<access-key-id>
# MINIO_ROOT_PASSWORD=<secret-access-key>
# MINIO_USE_SSL=true
# JWT_SECRET=<strong-random-secret>
# ACCESS_TOKEN_TTL_MINUTES=15
# REFRESH_TOKEN_TTL_HOURS=720
# USDA_API_BASE_URL=https://api.nal.usda.gov/fdc/v1
# USDA_API_KEY=<usda-api-key>
# EDAMAM_API_BASE_URL=https://api.edamam.com
# EDAMAM_APP_ID=<edamam-app-id>
# EDAMAM_APP_KEY=<edamam-app-key>
# FOOD_DETAILS_CACHE_TTL_MINUTES=60
# PRO_ALL_USERS=false
# PRO_USER_EMAILS=
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector.atlas-staging.svc.cluster.local:4318
# OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Secret storage recommendation:
# - Keep real staging/prod secrets in 1Password (or equivalent secret manager).
# - Inject at deploy/runtime via CI secrets; never commit real secret values.
